# ── Cloudflare KV (email storage) ──────────────────────────────────────────
# 1. Go to dash.cloudflare.com → Workers & Pages → KV → Create namespace
# 2. Go to My Profile → API Tokens → Create Token
#    Use "Edit Cloudflare Workers" template (gives KV read/write)
# 3. Your Account ID is on the right sidebar of any Cloudflare domain page

CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_KV_NAMESPACE_ID=your_kv_namespace_id_here
CLOUDFLARE_API_TOKEN=your_api_token_here

# ── Webhook security ────────────────────────────────────────────────────────
# Set any random string — used to verify requests to /api/webhook
WEBHOOK_SECRET=change-me
