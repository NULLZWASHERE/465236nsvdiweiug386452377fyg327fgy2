# ── Vercel KV ───────────────────────────────────────────────────────────────
# These are injected automatically when you add a KV database in Vercel:
#   Vercel dashboard → your project → Storage → Create Database → KV
# You do NOT need to fill these in manually — Vercel does it for you.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Webhook security ────────────────────────────────────────────────────────
# Any random string — used to verify requests from your Cloudflare email Worker
WEBHOOK_SECRET=change-me
